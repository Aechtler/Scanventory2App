# ── Datenbank ─────────────────────────────────────────────────
# Supabase Cloud:   postgresql://postgres.[ref]:[pw]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Supabase Lokal:   postgresql://postgres:postgres@localhost:54322/postgres
# Self-hosted:      postgresql://postgres:[pw]@[dein-server]:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Direkte DB-Verbindung (für Prisma Migrationen, kein PgBouncer)
# Supabase Cloud:   postgresql://postgres.[ref]:[pw]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Supabase Lokal:   postgresql://postgres:postgres@localhost:54322/postgres
# Self-hosted:      Gleich wie DATABASE_URL
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ── Supabase ──────────────────────────────────────────────────
# Cloud:      https://[project-ref].supabase.co
# Lokal:      http://localhost:54321
# Self-hosted: https://[deine-domain]
SUPABASE_URL=http://localhost:54321

# Aus Supabase Dashboard → Project Settings → API → service_role key
# Lokal: supabase status → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ───────────────────────────────────────────────────────
PORT=3000
API_KEY=change-me-to-a-secure-key

# ── eBay Sell API (optional) ──────────────────────────────────
# https://developer.ebay.com/my/keys
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_RU_NAME=

# ── Anthropic Claude API (KI-Plattformempfehlung) ─────────────
# https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# ── Expo Push Notifications (optional) ───────────────────────
# https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=
