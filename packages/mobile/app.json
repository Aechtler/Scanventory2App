{
  "expo": {
    "name": "Scandirwas",
    "slug": "scandirwas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "scandirwas",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scandirwas.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scandirwas benötigt Zugriff auf die Kamera um Gegenstände zu scannen.",
        "NSPhotoLibraryUsageDescription": "Scandirwas benötigt Zugriff auf deine Fotos um Bilder zu analysieren.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.scandirwas.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Scandirwas benötigt Zugriff auf die Kamera um Gegenstände zu scannen."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Scandirwas benötigt Zugriff auf deine Fotos um Bilder zu analysieren."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
