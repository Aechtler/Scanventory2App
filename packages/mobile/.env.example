# ScanApp Environment Variables
# Kopiere diese Datei zu .env und fülle die Werte aus

# API URL für Backend
EXPO_PUBLIC_API_URL=http://localhost:3000

# API Key für Backend-Authentifizierung
EXPO_PUBLIC_API_KEY=change-me-to-a-secure-key

# Vision API (OpenAI oder Google)
EXPO_PUBLIC_VISION_API_KEY=your_vision_api_key_here

# eBay API (Browse API benötigt App ID + Cert ID für Application Token)
EXPO_PUBLIC_EBAY_APP_ID=your_ebay_app_id_here
EXPO_PUBLIC_EBAY_CERT_ID=your_ebay_cert_id_here
# EXPO_PUBLIC_EBAY_OAUTH=your_user_token_here (NICHT für Browse API - nur für Trading/Selling APIs)

# Perplexity API (AI Market Value Search)
EXPO_PUBLIC_PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Kleinanzeigen API
EXPO_PUBLIC_KLEINANZEIGEN_TOKEN=your_kleinanzeigen_token_here
